+function validateQuestionProvenanceRuntimeGuard() {
+  const cases = [
+    {
+      label: 'null question defaults to UHR',
+      actual: () => getQuestionProvenance(null),
+      expected: 'uhr',
+    },
+    {
+      label: 'undefined question defaults to UHR',
+      actual: () => getQuestionProvenance(undefined),
+      expected: 'uhr',
+    },
+    {
+      label: 'string tags fail closed to UHR',
+      actual: () => getQuestionProvenance({ tags: 'editorial' }),
+      expected: 'uhr',
+    },
+    {
+      label: 'published-variant string tags fail closed to UHR',
+      actual: () => getQuestionProvenance({ tags: 'published-variant' }),
+      expected: 'uhr',
+    },
+    {
+      label: 'arbitrary includes object tags fail closed to UHR',
+      actual: () => getQuestionProvenance({ tags: { includes: () => true } }),
+      expected: 'uhr',
+    },
+    {
+      label: 'editorial array tags classify editorial',
+      actual: () => getQuestionProvenance({ tags: ['editorial'] }),
+      expected: 'editorial',
+    },
+    {
+      label: 'published-variant array tags classify derived',
+      actual: () => getQuestionProvenance({ tags: ['published-variant'] }),
+      expected: 'derived',
+    },
+    {
+      label: 'editorial tag takes precedence over derived',
+      actual: () => getQuestionProvenance({ tags: ['published-variant', 'editorial'] }),
+      expected: 'editorial',
+    },
+    {
+      label: 'invalid pool filters to empty',
+      actual: () => filterQuestionsByProvenance(null, { includeSupplementary: false }),
+      expected: [],
+    },
+    {
+      label: 'invalid options fail closed to UHR-only filtering',
+      actual: () =>
+        filterQuestionsByProvenance(
+          [
+            { id: 'uhr', tags: [] },
+            { id: 'derived', tags: ['published-variant'] },
+          ],
+          'invalid options',
+        ).map((question) => question.id),
+      expected: ['uhr'],
+    },
+    {
+      label: 'includeSupplementary true preserves supported pool',
+      actual: () =>
+        filterQuestionsByProvenance(
+          [
+            { id: 'uhr', tags: [] },
+            { id: 'derived', tags: ['published-variant'] },
+          ],
+          { includeSupplementary: true },
+        ).map((question) => question.id),
+      expected: ['uhr', 'derived'],
+    },
+    {
+      label: 'invalid provenance label falls back to Swedish UHR',
+      actual: () => getProvenanceLabel('banana', 'sv'),
+      expected: 'UHR',
+    },
+    {
+      label: 'invalid provenance description falls back to English UHR',
+      actual: () => getProvenanceDescription(null, 'en'),
+      expected: "Based on UHR's study material Sverige i fokus.",
+    },
+  ];
+
+  let runtimeValid = true;
+
+  cases.forEach(({ label, actual, expected }) => {
+    let actualValue;
+    try {
+      actualValue = actual();
+    } catch (error) {
+      runtimeValid = false;
+      fail(`question provenance runtime guard ${label} threw ${error.message}`);
+      return;
+    }
+
+    if (!jsonEqual(actualValue, expected)) {
+      runtimeValid = false;
+      fail(
+        `question provenance runtime guard ${label} returned ${JSON.stringify(
+          actualValue,
+        )}, expected ${JSON.stringify(expected)}`,
+      );
+    } else {
+      questionProvenanceRuntimeCasesValidated += 1;
+    }
+  });
+
+  if (runtimeValid && questionProvenanceRuntimeCasesValidated === cases.length) {
+    questionProvenanceRuntimeParityValidated = true;
+  }
+}
