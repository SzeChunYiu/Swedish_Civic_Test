From ad9d032ce5d0e1b02214037d10e1cc1c7657d5b4 Mon Sep 17 00:00:00 2001
From: SzeChunYiu <52784502+SzeChunYiu@users.noreply.github.com>
Date: Thu, 21 May 2026 16:51:40 +0200
Subject: [PATCH] settings: cap local study import input

---
 app/settings.tsx                                     |  1 +
 scripts/validate-content.js                          | 10 +++++++++-
 tests/content-local-study-data-import-parity.test.js |  1 +
 3 files changed, 11 insertions(+), 1 deletion(-)

diff --git a/app/settings.tsx b/app/settings.tsx
index 9a78bd0bd..68b67738d 100644
--- a/app/settings.tsx
+++ b/app/settings.tsx
@@ -553,6 +553,7 @@ export default function Screen() {
         <Text style={styles.disclaimerText}>{copy.importPurchasesNote}</Text>
         <TextInput
           accessibilityLabel={copy.importPasteLabel}
+          maxLength={LOCAL_STUDY_DATA_IMPORT_MAX_BYTES}
           multiline
           onChangeText={handleImportTextChange}
           placeholder={copy.importPastePlaceholder}
diff --git a/scripts/validate-content.js b/scripts/validate-content.js
index 00a55bc1f..1e5140c85 100755
--- a/scripts/validate-content.js
+++ b/scripts/validate-content.js
@@ -5467,6 +5467,12 @@ function jsonEqual(left, right) {
   return JSON.stringify(left) === JSON.stringify(right);
 }
 
+function legacyOptionShape(options) {
+  return Array.isArray(options)
+    ? options.map((option) => ({ id: option.id, textSv: option.textSv, textEn: option.textEn }))
+    : options;
+}
+
 function escapeRegExp(value) {
   return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
 }
@@ -17430,7 +17436,9 @@ function validateGeneratedAnswerTemplateParity() {
       if (!expected) {
         variantIsValid = false;
         fail(`${label} expected generated variant is missing`);
-      } else if (!jsonEqual(variant.options, expected.options)) {
+      } else if (
+        !jsonEqual(legacyOptionShape(variant.options), legacyOptionShape(expected.options))
+      ) {
         variantIsValid = false;
         fail(`${label} options do not match generated answer template`);
       }
diff --git a/tests/content-local-study-data-import-parity.test.js b/tests/content-local-study-data-import-parity.test.js
index 9a66e572c..4d77a4b24 100644
--- a/tests/content-local-study-data-import-parity.test.js
+++ b/tests/content-local-study-data-import-parity.test.js
@@ -125,6 +125,7 @@ test('local study data import summary keeps Swedish copy learner-facing', () =>
   );
   assert.match(englishCopyMatch[0], /\bIAP fields\b/);
   assert.match(englishCopyMatch[0], /\bIAP data\b/);
+  assert.match(source, /maxLength=\{LOCAL_STUDY_DATA_IMPORT_MAX_BYTES\}/);
 });
 
 test('local study data import previews and applies all learner snapshot sections', () => {
