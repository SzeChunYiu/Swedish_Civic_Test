   const {
     REMOVE_ADS_PRODUCT_ID,
diff --git a/tests/e2e/purchase-inflight-guard.spec.ts b/tests/e2e/purchase-inflight-guard.spec.ts
new file mode 100644
index 000000000..edb62ed4f
--- /dev/null
