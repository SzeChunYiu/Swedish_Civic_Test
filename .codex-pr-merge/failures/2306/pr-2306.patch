@@ -17735,6 +17805,7 @@ if (Array.isArray(questions)) {
       fail(`${label} reviewStatus is ${question.reviewStatus}`);
   });
 }
+validateQuestionReligiousFreedomParallelismArtifactText();
 
 validateMockExamConfig(
