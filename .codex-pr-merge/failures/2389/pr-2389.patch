+      cwd: repoRoot,
+      encoding: 'utf8',
+      env: process.env,
+    },
+  );
+  assert.equal(result.status, 0, result.stderr || result.stdout);
+  const jsonStart = result.stdout.indexOf('{');
+  assert.notEqual(jsonStart, -1, result.stdout);
+  return JSON.parse(result.stdout.slice(jsonStart));
+}
