+
+function validateQuestionProvenanceRuntimeGuard() {
+  const cases = [
+    {
+      label: 'missing tags defaults to UHR',
+      actual: () => getQuestionProvenance({ id: 'q-runtime-uhr' }),
+      expected: 'uhr',
+    },
+    {
+      label: 'empty string-array tags default to UHR',
+      actual: () => getQuestionProvenance({ tags: [] }),
+      expected: 'uhr',
+    },
+    {
+      label: 'published-variant string-array tags derive supplementary provenance',
+      actual: () => getQuestionProvenance({ tags: ['published-variant'] }),
+      expected: 'derived',
+    },
+    {
+      label: 'editorial string-array tags derive editorial provenance',
+      actual: () => getQuestionProvenance({ tags: ['editorial'] }),
+      expected: 'editorial',
+    },
+    {
+      label: 'editorial wins when both string-array tags are present',
+      actual: () => getQuestionProvenance({ tags: ['published-variant', 'editorial'] }),
+      expected: 'editorial',
+    },
+    {
+      label: 'null question defaults to UHR',
+      actual: () => getQuestionProvenance(null),
+      expected: 'uhr',
+    },
+    {
+      label: 'undefined question defaults to UHR',
+      actual: () => getQuestionProvenance(undefined),
+      expected: 'uhr',
+    },
+    {
+      label: 'primitive question defaults to UHR',
+      actual: () => getQuestionProvenance('editorial'),
+      expected: 'uhr',
+    },
+    {
+      label: 'string tags fail closed to UHR',
+      actual: () => getQuestionProvenance({ tags: 'editorial' }),
+      expected: 'uhr',
+    },
+    {
+      label: 'arbitrary includes-based tags fail closed to UHR',
+      actual: () => getQuestionProvenance({ tags: { includes: () => true } }),
+      expected: 'uhr',
+    },
+    {
+      label: 'mixed non-string tag arrays fail closed to UHR',
+      actual: () => getQuestionProvenance({ tags: ['published-variant', 7] }),
+      expected: 'uhr',
+    },
+    {
+      label: 'invalid provenance label falls back to Swedish UHR copy',
+      actual: () => getProvenanceLabel('banana', 'sv'),
+      expected: 'UHR',
+    },
+    {
+      label: 'non-array pools filter to an empty question list',
+      actual: () => filterQuestionsByProvenance(null, { includeSupplementary: false }).length,
+      expected: 0,
+    },
+  ];
+
+  let valid = true;
+  cases.forEach(({ label, actual, expected }) => {
+    let value;
+    try {
+      value = actual();
+    } catch (error) {
+      valid = false;
+      fail(`question provenance runtime guard ${label} threw ${error.message}`);
+      return;
+    }
+    if (value !== expected) {
+      valid = false;
+      fail(
+        `question provenance runtime guard ${label} expected ${JSON.stringify(
+          expected,
+        )}, got ${JSON.stringify(value)}`,
+      );
+      return;
+    }
+    questionProvenanceRuntimeCasesValidated += 1;
+  });
+
+  try {
+    const fallbackDescription = getProvenanceDescription('banana', 'xx');
+    if (fallbackDescription !== provenanceModule.provenanceCopy.uhr.descriptionSv) {
+      valid = false;
+      fail('question provenance runtime guard invalid description fallback drifted');
+    }
+  } catch (error) {
+    valid = false;
+    fail(`question provenance runtime guard invalid description fallback threw ${error.message}`);
+  }
+
+  questionProvenanceRuntimeParityValidated =
+    valid && questionProvenanceRuntimeCasesValidated === cases.length;
 }
 
