+function validateCountdownBannerHomeMount() {
+  const homeRouteSource = fs.readFileSync(path.join(repoRoot, 'app/(tabs)/home.tsx'), 'utf8');
+  let rulesValidated = 0;
+  let parity = true;
+
+  function reject(message) {
+    parity = false;
+    fail(message);
+  }
+
+  if (
+    /import\s+\{\s*CountdownBanner\s*\}\s+from\s+['"]\.\.\/\.\.\/components\/ui\/CountdownBanner['"];?/.test(
+      homeRouteSource,
+    )
+  ) {
+    rulesValidated += 1;
+  } else {
+    reject('Home route must import CountdownBanner');
+  }
+
+  if (/<CountdownBanner\s+language=\{language\}\s*\/>/.test(homeRouteSource)) {
+    rulesValidated += 1;
+  } else {
+    reject('Home route must mount CountdownBanner with the selected language');
+  }
+
+  return { rulesValidated, parity };
+}
