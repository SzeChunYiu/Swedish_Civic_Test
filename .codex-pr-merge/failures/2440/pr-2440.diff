+async function expectProvenanceSourceNoteToggle(
+  page: Page,
+  contract: ProvenanceSourceNoteContract,
+) {
+  const badge = page.getByRole('button', { name: contract.badgeLabel }).first();
+  const sourceNotes = page.getByText(contract.sourceNotePattern);
+
+  await expect(badge).toBeVisible();
+  await badge.scrollIntoViewIfNeeded();
+  await expect(badge).toHaveAttribute('aria-expanded', 'false');
+  await expect(sourceNotes).toHaveCount(0);
+
+  await badge.click();
+  await expect(badge).toHaveAttribute('aria-expanded', 'true');
+  await expect(sourceNotes.first()).toBeVisible();
+
+  await badge.click();
+  await expect(badge).toHaveAttribute('aria-expanded', 'false');
+  await expect(sourceNotes).toHaveCount(0);
+
+  await badge.focus();
+  await page.keyboard.press('Enter');
+  await expect(badge).toHaveAttribute('aria-expanded', 'true');
+  await expect(sourceNotes.first()).toBeVisible();
+
+  await page.keyboard.press('Space');
+  await expect(badge).toHaveAttribute('aria-expanded', 'false');
+  await expect(sourceNotes).toHaveCount(0);
+}
