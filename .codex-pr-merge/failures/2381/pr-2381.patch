+  assert.match(validatorSource, new RegExp(`focusedValidationRequested\\('${id}'\\)`));
+  assert.match(validatorSource, new RegExp(`printFocusedValidationSummary\\('${id}'`));
+  assert.match(validatorSource, summaryPattern);
+}
