       sourceQuestions: Array.isArray(sourceQuestions) ? sourceQuestions.length : 0,
diff --git a/tests/content-test-script-routing.test.js b/tests/content-test-script-routing.test.js
index 3c1687a62..a59cb0a3a 100644
--- a/tests/content-test-script-routing.test.js
